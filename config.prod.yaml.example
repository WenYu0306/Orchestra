# 生产环境配置模板
# 使用方式: cp config.prod.yaml.example config.yaml
# 与开发环境的区别在注释中标出

# ============ 平台设置 ============
platform:
  name: "boss"
  login_method: "scan_qr"

# ============ 简历 ============
resume:
  pdf_path: "./my_resume.pdf"

# ============ 搜索设置 ============
search:
  primary_keywords:
    - "AI应用开发"
    - "LLM"
    - "全栈开发"
  dynamic_keywords: true

  cities:
    - name: "北京"
      min_salary: 15000
    - name: "长春"
      min_salary: 8000

  exclude:
    - "远程"
    - "全国"

# ============ 匹配与分层 ============
matching:
  criteria:
    skill_overlap_weight: 50
    experience_relevance: 30
    qualification_match: 20
    cross_industry_bonus: true
    cross_industry_bonus_value: 5

  tiers:
    high:
      min_score: 80
      count: 5
    medium:
      min_score: 60
      max_score: 79
      count: 7
    try:
      min_score: 40
      max_score: 59
      count: 8

# ============ 安全 ============
safety:
  min_delay: 5        # 生产环境加大延迟
  max_delay: 12
  captcha_handling: "pause_notify"
  headless: false

# ============ Web UI ============
web_ui:
  host: "127.0.0.1"
  port: 5000
  auto_open: false     # 生产环境不自动打开浏览器
