graph TB
    subgraph step1["① 你点一下按钮"]
        browser["🌐 前端页面<br/>点「开始分析」"]
    end

    subgraph step2["② Agent 启动 Chrome"]
        chrome["🧠 nodriver 启动 Chrome<br/>（用你之前登过的 cookie，不用重新扫码）"]
        boss["打开 BOSS 直聘职位页"]
    end

    subgraph step3["③ 搜岗位 不用手"]
        search["🔍 自动搜 22 个关键词<br/>北京12个 + 长春10个<br/>（AI应用开发、LSM、全栈…）"]
        api["直接调 BOSS 后台 API<br/>拿到 30 个/关键词的 JSON 数据"]
    end

    subgraph step4["④ 过安检"]
        v1["🏙️ 城市对不对？<br/>（之前长春编码错了 搜了南京 已修）"]
        v2["💰 薪资够不够？<br/>（北京低于15K、长春低于8K 直接跳）"]
        v3["🏢 公司名正不正常？<br/>（空的、?、太长 都告警）"]
    end

    subgraph step5["⑤ DeepSeek 评两轮"]
        round1["📝 第一轮：标签快速打分<br/>（公司名、技能、经验、行业）"]
        top30["取前 30 名"]
        round2["📋 第二轮：详情精准打分<br/>（调详情 API 拿完整 JD<br/> 跟你的真简历对比）"]
    end

    subgraph step6["⑥ 最终排名"]
        tier["📊 前5名 high / 中7名 medium / 后8名 try<br/>（JD长的优先 短的补不足）"]
    end

    subgraph step7["⑦ 你看到的"]
        result["✅ 前端显示 20 个推荐岗位<br/>每个带分数、理由、招呼语<br/>（干跑模式 不发出去）"]
    end

    step1 --> step2
    step2 --> step3
    step3 --> step4
    step4 --> step5
    step5 --> step6
    step6 --> step7

    style step1 fill:#ffe66d,color:#333
    style step7 fill:#ffe66d,color:#333
    style step4 fill:#ff6b6b,color:#fff
