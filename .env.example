# ============ API Keys ============
# DeepSeek V4 Pro — 文本推理（简历-JD 匹配、搜索词生成、招呼语、虚假招聘甄别）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Qwen3-VL-Flash — 浏览器视觉操作（识别按钮、表单、验证码状态）
QWEN_VL_API_KEY=your_qwen_vl_api_key_here
QWEN_VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen3-vl-flash

# ============ 真发送控制 ============
# 每轮最多真发送数量，0=全部干跑（默认）
APPLY_LIMIT=0

# ============ 个人信息（敏感数据，不放在 config.yaml 里） ============
NAME=
PHONE=
EMAIL=
